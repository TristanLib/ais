# Large generated evidence files; keep summary tables/manifests instead.
outputs/**/per_sample_errors.csv
outputs/audit/*split_manifest.csv

# Exclude specific large synthetic data
data/raw/realistic_synthetic_ais.csv
data/raw/comprehensive_realistic_ais.csv

# But keep sample and config files
!configs/
!scripts/
!src/
!data/
!data/README.md
!data/meta/
!data/meta/*.json

# Keep important result files
!outputs/models/*.json
!outputs/figures/*.png
